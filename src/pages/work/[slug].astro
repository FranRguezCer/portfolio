---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { STR, WORK } from '../../data/site';

export function getStaticPaths() {
  return WORK.map((w) => ({ params: { slug: w.slug } }));
}

const { slug } = Astro.params;
const idx = WORK.findIndex((w) => w.slug === slug);
const w = WORK[idx];
if (!w) throw new Error(`Unknown work slug: ${slug}`);
const prev = WORK[(idx - 1 + WORK.length) % WORK.length];
const next = WORK[(idx + 1) % WORK.length];

const en = STR.en;
const es = STR.es;
const basePath = '/portfolio';
---
<BaseLayout
  title={`${w.title.en} · Francisco Rodríguez`}
  description={w.oneLiner.en}
  route="work"
>
  <!-- Breadcrumb -->
  <div class="container">
    <section style="padding-top: 56px; padding-bottom: 24px;">
      <div class="mono" style="font-size: 12px; color: var(--muted);">
        <a
          href={`${basePath}/#sistemas-destacados`}
          style="color: inherit; text-decoration: none;"
          data-en={en.crumbWork}
          data-es={es.crumbWork}
        >{en.crumbWork}</a>
        <span style="margin: 0 10px;">/</span>
        <span style="color: var(--fg);">{w.id} · {w.slug}</span>
      </div>
    </section>
  </div>

  <!-- Hero -->
  <div class="container">
    <section style="padding: 8px 0 40px;">
      <div class="eyebrow">
        <span class="num">{w.id}</span><span>/</span>
        <span data-en={w.domain.en} data-es={w.domain.es}>{w.domain.en}</span>
      </div>
      <h1
        style="font-size: 64px; line-height: 1.0; letter-spacing: -0.028em; font-weight: 500; margin: 24px 0 24px; max-width: 20ch;"
        data-en={w.title.en}
        data-es={w.title.es}
      >{w.title.en}</h1>
      <p
        class="body-lg"
        style="max-width: 64ch; font-size: 20px;"
        data-en={w.oneLiner.en}
        data-es={w.oneLiner.es}
      >{w.oneLiner.en}</p>
      <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-top: 28px;">
        {w.stack.map((s) => (
          <span class="chip">{s}</span>
        ))}
      </div>
    </section>
  </div>

  <!-- Body -->
  <div class="container">
    <section style="padding: 32px 0 24px; border-top: 1px solid var(--hairline);">
      <div style="max-width: 760px; margin: 0 auto;">
        <div class="eyebrow" style="margin-top: 32px;">
          <span class="num">01</span><span>/</span>
          <span data-en={en.overview} data-es={es.overview}>{en.overview}</span>
        </div>
        <div style="margin-top: 24px; display: flex; flex-direction: column; gap: 16px;">
          {w.body.en.map((para, i) => (
            <p
              class="body"
              style="font-size: 17px; line-height: 1.7; margin: 0;"
              data-en={para}
              data-es={w.body.es[i]}
            >{para}</p>
          ))}
        </div>

        <div class="eyebrow" style="margin-top: 56px;">
          <span class="num">02</span><span>/</span>
          <span data-en={w.notesLabel.en} data-es={w.notesLabel.es}>{w.notesLabel.en}</span>
        </div>
        <ul style="margin-top: 16px; padding: 0; list-style: none;">
          {w.notes.en.map((n, i) => (
            <li style="padding: 14px 0 14px 28px; border-top: 1px solid var(--hairline); position: relative; font-size: 15px; color: var(--fg-soft); line-height: 1.55;">
              <span style="position: absolute; left: 0; top: 22px; width: 14px; height: 1px; background: var(--warm);"></span>
              <span data-en={n} data-es={w.notes.es[i]}>{n}</span>
            </li>
          ))}
        </ul>

        <div style="margin-top: 56px; padding-top: 24px; border-top: 1px solid var(--hairline);">
          <a
            href={`${basePath}/#sistemas-destacados`}
            class="mono"
            style="font-size: 12px; color: var(--muted); text-decoration: none; letter-spacing: 0.06em; text-transform: uppercase;"
            data-en="← Back to work"
            data-es="← Volver a trabajo"
          >← Back to work</a>
        </div>
      </div>
    </section>
  </div>

  <!-- Up next -->
  <div class="container">
    <div
      class="home-grid-2"
      style="border-top: 1px solid var(--hairline); margin-top: 32px; padding-top: 32px; padding-bottom: 64px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px;"
    >
      <a
        href={`${basePath}/work/${prev.slug}/`}
        style="border: 1px solid var(--border); padding: 28px; text-decoration: none; color: inherit;"
      >
        <div class="mono" style="font-size: 11px; color: var(--muted); margin-bottom: 8px; letter-spacing: 0.06em; text-transform: uppercase;" data-en="← Previous" data-es="← Anterior">← Previous</div>
        <div style="font-size: 18px; font-weight: 500; letter-spacing: -0.005em;" data-en={prev.title.en} data-es={prev.title.es}>{prev.title.en}</div>
      </a>
      <a
        href={`${basePath}/work/${next.slug}/`}
        style="border: 1px solid var(--border); padding: 28px; text-decoration: none; color: inherit; text-align: right;"
      >
        <div class="mono" style="font-size: 11px; color: var(--muted); margin-bottom: 8px; letter-spacing: 0.06em; text-transform: uppercase;" data-en="Next →" data-es="Siguiente →">Next →</div>
        <div style="font-size: 18px; font-weight: 500; letter-spacing: -0.005em;" data-en={next.title.en} data-es={next.title.es}>{next.title.en}</div>
      </a>
    </div>
  </div>
</BaseLayout>
