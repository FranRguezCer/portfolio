---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SkillCard from '../../components/SkillCard.astro';
import { t } from '../../i18n/ui';

import pythonIcon from '../../assets/icons/python.svg?raw';
import rIcon from '../../assets/icons/r.svg?raw';
import sqlIcon from '../../assets/icons/sql.svg?raw';
import tableauIcon from '../../assets/icons/tableau.svg?raw';
import powerbiIcon from '../../assets/icons/powerbi.svg?raw';
import excelIcon from '../../assets/icons/excel.svg?raw';
import gitIcon from '../../assets/icons/git.svg?raw';
import dockerIcon from '../../assets/icons/docker.svg?raw';

const lang = 'es' as const;
const skills = (await getCollection('skills', ({ data }) => data.locale === lang))
  .sort((a, b) => a.data.order - b.data.order);

const iconMap: Record<string, string> = {
  python: pythonIcon,
  r: rIcon,
  sql: sqlIcon,
  'data-visualization': `${tableauIcon}${powerbiIcon}`,
  excel: excelIcon,
  git: gitIcon,
  docker: dockerIcon,
};
---
<BaseLayout title="Skills · Francisco Rodriguez" description="Skills tecnicos y herramientas." lang={lang}>
  <section class="skills">
    <header>
      <h1>{t(lang, 'section.skills')}</h1>
    </header>
    <div class="grid">
      {skills.map((entry) => (
        <SkillCard entry={entry} iconHtml={iconMap[entry.data.icon] ?? ''} />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .skills { max-inline-size: 72rem; margin-inline: auto; padding: 3rem 1.5rem; display: flex; flex-direction: column; gap: 2rem; }
  h1 { font-size: 2rem; margin: 0; font-weight: 700; }
  .grid { display: grid; gap: 1.5rem; grid-template-columns: 1fr; }
  @media (min-width: 720px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 960px) { .grid { grid-template-columns: repeat(3, 1fr); } }
</style>
