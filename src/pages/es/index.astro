---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { t, routes } from '../../i18n/ui';
import photo from '../../assets/photo.jpg';

const lang = 'es' as const;
const [homePage] = await getCollection('pages', ({ id, data }) => id.endsWith('/home') && data.locale === lang);
const { Content: HomeContent } = await render(homePage);

const allProjects = await getCollection('projects', ({ data }) => data.locale === lang);
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Francisco Rodriguez — Data Scientist" description="Data Scientist enfocado en machine learning, automatizacion de ETLs y analitica. Portfolio de proyectos, skills y experiencia." lang={lang}>
  <section class="hero">
    <div class="hero-text">
      <HomeContent />
      <div class="cta">
        <a class="cta-primary" href={routes[lang].projects}>{t(lang, 'cta.viewAllProjects')}</a>
        <a class="cta-secondary" href="/portfolio/cv/Francisco_Rodriguez_CV_en.pdf" download>{t(lang, 'cta.viewCV')}</a>
      </div>
    </div>
    <Image src={photo} alt="Retrato de Francisco Rodriguez" widths={[256, 512]} sizes="(min-width: 720px) 320px, 100vw" class="hero-photo" />
  </section>

  {featured.length > 0 && (
    <section class="featured">
      <h2>{t(lang, 'section.projects')}</h2>
      <div class="grid">
        {featured.map((entry) => <ProjectCard entry={entry} lang={lang} />)}
      </div>
      <a class="see-all" href={routes[lang].projects}>{t(lang, 'cta.viewAllProjects')} &rarr;</a>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    max-inline-size: 72rem;
    margin-inline: auto;
    padding: 4rem 1.5rem;
    display: grid;
    gap: 3rem;
    grid-template-columns: 1fr;
    align-items: center;
  }
  @media (min-width: 720px) {
    .hero { grid-template-columns: 1.5fr 1fr; }
  }
  .hero-text { display: flex; flex-direction: column; gap: 1rem; }
  .hero-text :global(h1) { font-size: clamp(2rem, 4vw, 3rem); margin: 0; font-weight: 700; }
  .hero-text :global(p) { color: var(--color-muted); line-height: 1.6; font-size: 1.05rem; margin: 0; }
  .hero-photo {
    inline-size: 100%;
    max-inline-size: 20rem;
    block-size: auto;
    border-radius: 0.75rem;
    justify-self: center;
  }
  .cta { display: flex; gap: 0.75rem; margin-block-start: 1rem; }
  .cta-primary, .cta-secondary {
    padding: 0.6rem 1.1rem;
    border-radius: 0.375rem;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
  }
  .cta-primary { background: var(--color-fg); color: var(--color-bg); }
  .cta-primary:hover { background: var(--color-accent); }
  .cta-secondary { border: 1px solid var(--color-border); color: var(--color-fg); }
  .cta-secondary:hover { border-color: var(--color-fg); }
  .cta-primary:focus-visible, .cta-secondary:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }
  .featured {
    max-inline-size: 72rem;
    margin-inline: auto;
    padding: 2rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .featured h2 { font-size: 1.5rem; margin: 0; font-weight: 600; }
  .grid { display: grid; gap: 1.5rem; grid-template-columns: 1fr; }
  @media (min-width: 720px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 960px) { .grid { grid-template-columns: repeat(3, 1fr); } }
  .see-all { color: var(--color-fg); text-decoration: none; font-weight: 500; align-self: flex-start; }
  .see-all:hover { color: var(--color-accent); }
</style>
