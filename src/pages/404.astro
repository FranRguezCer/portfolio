---
import BaseLayout from '../layouts/BaseLayout.astro';
import { routes } from '../i18n/ui';

const lang = 'en' as const;
---
<BaseLayout title="Not found · Francisco Rodriguez" description="The page you were looking for does not exist." lang={lang}>
  <section class="not-found">
    <h1>404 &mdash; Not found</h1>
    <p>The page you were looking for does not exist or has moved.</p>
    <a class="back" href={routes[lang].home}>&larr; Back to home</a>
  </section>
</BaseLayout>

<style>
  .not-found { max-inline-size: 40rem; margin-inline: auto; padding: 6rem 1.5rem; text-align: center; display: flex; flex-direction: column; gap: 1rem; align-items: center; }
  h1 { font-size: 2rem; margin: 0; font-weight: 700; }
  p { color: var(--color-muted); margin: 0; }
  .back { color: var(--color-fg); font-weight: 500; text-decoration: none; }
  .back:hover { color: var(--color-accent); }
</style>
