---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactChannel from '../components/ContactChannel.astro';
import { t } from '../i18n/ui';

import emailIcon from '../assets/icons/email.svg?raw';
import linkedinIcon from '../assets/icons/linkedin.svg?raw';
import githubIcon from '../assets/icons/github.svg?raw';

const lang = 'en' as const;
const [contactPage] = await getCollection('pages', ({ id, data }) => id.endsWith('/contact') && data.locale === lang);
const { Content: ContactContent } = await render(contactPage);

const email = 'portfolio.fjrguezcer@gmail.com';
const linkedinUrl = 'https://linkedin.com/in/franciscojoserodriguezcerezo';
const githubUrl = 'https://github.com/FranRguezCer';
---
<BaseLayout title="Contact · Francisco Rodriguez" description="Reach Francisco Rodriguez by email, LinkedIn or GitHub." lang={lang}>
  <section class="contact">
    <header>
      <h1>{t(lang, 'section.contact')}</h1>
      <ContactContent />
    </header>
    <address>
      <ContactChannel iconHtml={emailIcon} label={t(lang, 'contact.email')} href={`mailto:${email}`} display={email} />
      <ContactChannel iconHtml={linkedinIcon} label={t(lang, 'contact.linkedin')} href={linkedinUrl} display="linkedin.com/in/franciscojoserodriguezcerezo" external />
      <ContactChannel iconHtml={githubIcon} label={t(lang, 'contact.github')} href={githubUrl} display="github.com/FranRguezCer" external />
    </address>
  </section>
</BaseLayout>

<style>
  .contact { max-inline-size: 48rem; margin-inline: auto; padding: 3rem 1.5rem; display: flex; flex-direction: column; gap: 2rem; }
  h1 { font-size: 2rem; margin: 0; font-weight: 700; }
  header :global(p) { color: var(--color-muted); margin: 0.5rem 0 0; line-height: 1.6; }
  address { font-style: normal; display: flex; flex-direction: column; gap: 1rem; }
</style>
