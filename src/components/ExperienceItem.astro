---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { t, type Locale } from '../i18n/ui';

interface Props {
  entry: CollectionEntry<'experience'>;
  lang: Locale;
}

const { entry, lang } = Astro.props;
const { role, organization, location, startDate, endDate, current } = entry.data;
const { Content } = await render(entry);

const formatter = new Intl.DateTimeFormat(lang === 'es' ? 'es-ES' : 'en-US', { year: 'numeric', month: 'short' });
const startStr = formatter.format(startDate);
const endStr = current || !endDate ? t(lang, 'date.present') : formatter.format(endDate);
const isoStart = startDate.toISOString().slice(0, 10);
const isoEnd = endDate ? endDate.toISOString().slice(0, 10) : '';
---
<article class="experience-item">
  <header>
    <h3>{role}</h3>
    <p class="org">{organization}{location && <>, <span>{location}</span></>}</p>
    <p class="dates">
      <time datetime={isoStart}>{startStr}</time>
      <span aria-hidden="true"> &mdash; </span>
      {current || !endDate
        ? <span>{endStr}</span>
        : <time datetime={isoEnd}>{endStr}</time>
      }
    </p>
  </header>
  <div class="body"><Content /></div>
</article>

<style>
  .experience-item {
    padding-block: 1.5rem;
    border-block-end: 1px solid var(--color-border);
  }
  .experience-item:last-child {
    border-block-end: none;
  }
  h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
  }
  .org {
    margin: 0.25rem 0 0;
    color: var(--color-muted);
    font-size: 0.95rem;
  }
  .dates {
    margin: 0.25rem 0 0;
    color: var(--color-muted);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
  }
  .body {
    margin-block-start: 0.75rem;
    color: var(--color-fg);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .body :global(ul) {
    padding-inline-start: 1.25rem;
    margin: 0.5rem 0 0;
  }
  .body :global(li) {
    margin-block: 0.25rem;
  }
</style>
