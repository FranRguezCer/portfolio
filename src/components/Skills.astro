---
import { Icon } from 'astro-icon/components';
import { Database, DatabaseZap } from '@lucide/astro';

const skills = [
  { name: "Python", icon: "simple-icons:python" },
  { name: "Pandas", icon: "simple-icons:pandas" },
  { name: "PySpark", icon: "simple-icons:apachespark" },
  { name: "SQL", icon: "lucide:database-solid" },
  { name: "TensorFlow", icon: "simple-icons:tensorflow" },
  { name: "PyTorch", icon: "simple-icons:pytorch" },
  { name: "LangChain", icon: "simple-icons:langchain" },
  { name: "LangGraph", icon: "simple-icons:langgraph" },
  { name: "Scikit-learn", icon: "simple-icons:scikitlearn" },
  { name: "Power BI", icon: "simple-icons:powerbi" },
  { name: "ChromaDB", icon: "lucide:database" },
  { name: "Git", icon: "simple-icons:git" },
];

---

<section id="skills" class="section section--surface">
  <div class="skills__container">
    <h2 class="section__title reveal">Skills</h2>
    <div class="skills__carousel reveal">
      <div class="skills__track">
        {[...skills, ...skills].map((skill) => (
          <div class="skills__item">
            {skill.icon === 'lucide:database-solid' ? (
              <Database class="skills__icon" size={48} fill="currentColor" />
            ) : skill.icon === 'lucide:database' ? (
              <Database class="skills__icon" size={48} />
            ) : (
              <Icon name={skill.icon} class="skills__icon" />
            )}
            <span class="skills__label">{skill.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .skills__container {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .skills__carousel {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
  }

  .skills__track {
    display: flex;
    gap: var(--space-6);
    width: max-content;
    animation: carousel-scroll 40s linear infinite;
  }

  .skills__track:hover {
    animation-play-state: paused;
  }

  .skills__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-6) var(--space-8);
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
    min-width: 120px;
    transition: box-shadow var(--transition-base);
  }

  .skills__item:hover {
    box-shadow: var(--shadow-glow);
  }

  .skills__icon {
    width: 48px;
    height: 48px;
    margin-block-end: var(--space-3);
    transition: transform var(--transition-base);
    color: var(--color-accent);
  }

  .skills__item:hover .skills__icon {
    transform: scale(1.1);
  }

  .skills__label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    text-align: center;
    white-space: nowrap;
  }

  @keyframes carousel-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .skills__track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: auto;
    }

    .skills__carousel {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }
</style>
