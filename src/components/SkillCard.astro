---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'skills'>;
  iconHtml?: string;
}

const { entry, iconHtml } = Astro.props;
const { name, tags } = entry.data;
const { Content } = await entry.render();
---
<article class="skill-card">
  {iconHtml && <div class="icon" set:html={iconHtml} aria-hidden="true" />}
  <header>
    <h3>{name}</h3>
  </header>
  <div class="body">
    <Content />
  </div>
  {tags.length > 0 && (
    <ul class="tags" aria-label="Tags">
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>
  )}
</article>

<style>
  .skill-card {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1.5rem;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .icon {
    inline-size: 2.5rem;
    block-size: 2.5rem;
    color: var(--color-fg);
  }
  .icon :global(svg) {
    inline-size: 100%;
    block-size: 100%;
  }
  h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }
  .body {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .body :global(p) {
    margin: 0;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tags li {
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    background: var(--color-surface);
    color: var(--color-muted);
    border-radius: 0.25rem;
  }
</style>
