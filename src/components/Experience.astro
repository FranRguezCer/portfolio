---
const experiences = [
  {
    title: 'Data & AI Engineer',
    company: 'Gran Telescopio Canarias (GTC)',
    date: '2025 – Present',
    description:
      'Building datalake ingestion pipelines with Spark, developing agentic workflows based on LangGraph using RAG with vector databases and local LLM inference, and creating an internal analytics platform to track telescope effective time usage by crossing incidence and night report data.',
  },
  {
    title: 'Data Scientist',
    company: 'Cabildo de La Palma',
    date: '2024 – 2025',
    description:
      'Automated ETL pipelines and reports, designed Power BI dashboards and geospatial visualizations with ESRI ArcGIS platforms. Provided analytics and studied relationships between CO2 levels in the volcano exclusion zone from the 2021 La Palma eruption and other environmental factors.',
  },
  {
    title: 'Freelance Tutor',
    company: 'Self-employed',
    date: '2018 – 2020',
    description:
      'Provided personalized tutoring to secondary-level students in science and mathematics.',
  },
];
---

<section id="experience" class="section">
  <div class="container">
    <h2 class="section__title reveal">Experience</h2>

    <div class="timeline">
      {
        experiences.map((exp, index) => (
          <div class={`timeline__item ${index % 2 === 0 ? 'timeline__item--left' : 'timeline__item--right'}`}>
            <div class="timeline__dot" />
            <article class={`timeline__card reveal ${index % 2 === 0 ? 'reveal--left' : 'reveal--right'}`} style={`transition-delay: ${index * 100}ms`}>
              <h3 class="timeline__title">{exp.title}</h3>
              <span class="timeline__company">{exp.company}</span>
              <span class="timeline__date">{exp.date}</span>
              <p class="timeline__description">{exp.description}</p>
            </article>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    max-width: 800px;
    margin-inline: auto;
    padding-left: var(--space-8);
  }

  /* Vertical line */
  .timeline::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 5px;
    width: 2px;
    background-color: var(--color-border);
  }

  .timeline__item {
    position: relative;
    margin-bottom: var(--space-10);
    padding-left: var(--space-6);
  }

  .timeline__item:last-child {
    margin-bottom: 0;
  }

  .timeline__dot {
    position: absolute;
    top: var(--space-6);
    left: calc(-1 * var(--space-8) + 0px);
    width: 12px;
    height: 12px;
    background-color: var(--color-accent);
    border-radius: 50%;
    z-index: 1;
    box-shadow: 0 0 8px rgba(34, 211, 238, 0.3);
  }

  .timeline__card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: var(--space-6);
    border-radius: 8px;
    box-shadow: var(--shadow-sm);
  }

  .timeline__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }

  .timeline__company {
    display: block;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: var(--space-1);
  }

  .timeline__date {
    display: block;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-3);
  }

  .timeline__description {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  /* Desktop: centered timeline with alternating cards */
  @media (min-width: 768px) {
    .timeline {
      padding-left: 0;
    }

    .timeline::before {
      left: 50%;
      transform: translateX(-50%);
    }

    .timeline__item {
      width: 50%;
      padding-left: 0;
    }

    .timeline__item--left {
      margin-left: 0;
      padding-right: var(--space-10);
      text-align: right;
    }

    .timeline__item--right {
      margin-left: 50%;
      padding-left: var(--space-10);
      text-align: left;
    }

    .timeline__item--left .timeline__dot {
      left: auto;
      right: calc(-1 * var(--space-10) + 19px);
    }

    .timeline__item--right .timeline__dot {
      left: calc(-1 * var(--space-10) + 19px);
    }
  }
</style>
