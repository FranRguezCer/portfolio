---
const experiences = [
  {
    title: 'Senior Data Engineer',
    company: 'Tech Company A',
    date: '2022–Present',
    description:
      'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.',
  },
  {
    title: 'Data Scientist',
    company: 'Tech Company B',
    date: '2020–2022',
    description:
      'Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris. Duis aute irure dolor in reprehenderit in voluptate velit.',
  },
  {
    title: 'Junior Data Analyst',
    company: 'Tech Company C',
    date: '2018–2020',
    description:
      'Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia. Deserunt mollit anim id est laborum sed perspiciatis.',
  },
];
---

<section id="experience" class="section">
  <div class="container">
    <h2 class="section__title reveal">Experience</h2>

    <div class="timeline">
      {
        experiences.map((exp, index) => (
          <div class={`timeline__item ${index % 2 === 0 ? 'timeline__item--left' : 'timeline__item--right'}`}>
            <div class="timeline__dot" />
            <article class="timeline__card reveal" style={`transition-delay: ${index * 100}ms`}>
              <h3 class="timeline__title">{exp.title}</h3>
              <span class="timeline__company">{exp.company}</span>
              <span class="timeline__date">{exp.date}</span>
              <p class="timeline__description">{exp.description}</p>
            </article>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    max-width: 800px;
    margin-inline: auto;
    padding-left: var(--space-8);
  }

  /* Vertical line */
  .timeline::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 5px;
    width: 2px;
    background-color: var(--color-surface);
  }

  .timeline__item {
    position: relative;
    margin-bottom: var(--space-10);
    padding-left: var(--space-6);
  }

  .timeline__item:last-child {
    margin-bottom: 0;
  }

  .timeline__dot {
    position: absolute;
    top: var(--space-6);
    left: calc(-1 * var(--space-8) + 0px);
    width: 12px;
    height: 12px;
    background-color: var(--color-accent);
    border-radius: 50%;
    z-index: 1;
  }

  .timeline__card {
    background-color: var(--color-white);
    padding: var(--space-6);
    border-radius: 8px;
    box-shadow: var(--shadow-sm);
  }

  .timeline__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }

  .timeline__company {
    display: block;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: var(--space-1);
  }

  .timeline__date {
    display: block;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-3);
  }

  .timeline__description {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  /* Desktop: centered timeline with alternating cards */
  @media (min-width: 768px) {
    .timeline {
      padding-left: 0;
    }

    .timeline::before {
      left: 50%;
      transform: translateX(-50%);
    }

    .timeline__item {
      width: 50%;
      padding-left: 0;
    }

    .timeline__item--left {
      margin-left: 0;
      padding-right: var(--space-10);
      text-align: right;
    }

    .timeline__item--right {
      margin-left: 50%;
      padding-left: var(--space-10);
      text-align: left;
    }

    .timeline__item--left .timeline__dot {
      left: auto;
      right: calc(-1 * var(--space-10) + 19px);
    }

    .timeline__item--right .timeline__dot {
      left: calc(-1 * var(--space-10) + 19px);
    }
  }
</style>
