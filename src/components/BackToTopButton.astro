---
// Fixed back-to-top button. Visibility, smooth-scroll behavior and the
// bilingual tooltip are wired in src/scripts/backToTop.ts.
---
<button
  id="back-top"
  class="back-top"
  type="button"
  aria-label="Back to top"
  data-tip="Back to top"
  data-tip-en="Back to top"
  data-tip-es="Volver arriba"
>
  <span class="back-top__glyph" aria-hidden="true">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 19V5"></path>
      <path d="m5 12 7-7 7 7"></path>
    </svg>
  </span>
</button>
