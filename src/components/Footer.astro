---
import { t, type Locale } from '../i18n/ui';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-inner">
    <ul class="social" aria-label={lang === 'es' ? 'Redes' : 'Social links'}>
      <li>
        <a
          href="https://linkedin.com/in/franciscojoserodriguezcerezo"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
        >LinkedIn</a>
      </li>
      <li>
        <a
          href="https://github.com/FranRguezCer"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
        >GitHub</a>
      </li>
    </ul>
    <small>&copy; {year} Francisco Rodriguez. {t(lang, 'footer.rights')}</small>
  </div>
</footer>

<style>
  .site-footer {
    border-block-start: 1px solid var(--color-border);
    background: var(--color-bg);
    margin-block-start: 4rem;
  }
  .footer-inner {
    max-inline-size: 72rem;
    margin-inline: auto;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  .social {
    display: flex;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .social a {
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.9rem;
  }
  .social a:hover {
    color: var(--color-fg);
  }
  .social a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 0.125rem;
  }
  small {
    color: var(--color-muted);
    font-size: 0.8rem;
  }
</style>
