---
import { STR, EDUCATION } from '../../data/site';

const en = STR.en;
const es = STR.es;
---
<div class="container">
  <section id="education" class="b-section">
    <div class="section-head">
      <div>
        <div class="eyebrow">
          <span class="num">05</span><span>/</span>
          <span data-en={en.sectionSubs.education} data-es={es.sectionSubs.education}>{en.sectionSubs.education}</span>
        </div>
        <h2 class="h1" style="margin-top: 12px;" data-en={en.sections.education} data-es={es.sections.education}>{en.sections.education}</h2>
      </div>
    </div>
    <div
      class="home-grid-3"
      style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 24px;"
    >
      {EDUCATION.map((e) => (
        <article style="border: 1px solid var(--border); padding: 32px; display: flex; flex-direction: column; gap: 14px;">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <span class="mono" style="font-size: 11px; color: var(--warm);">{e.id}</span>
            <span
              class="mono"
              style="font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em;"
              data-en={e.tag.en}
              data-es={e.tag.es}
            >{e.tag.en}</span>
          </div>
          <div style="display: flex; flex-direction: column; gap: 6px;">
            <div class="mono" style="font-size: 12px; color: var(--muted);" data-en={e.period.en} data-es={e.period.es}>{e.period.en}</div>
            <div
              style="font-size: 24px; font-weight: 500; letter-spacing: -0.01em; line-height: 1.2; margin-top: 2px;"
              data-en={e.title.en}
              data-es={e.title.es}
            >{e.title.en}</div>
            <div class="small" data-en={e.org.en} data-es={e.org.es}>{e.org.en}</div>
          </div>
          <p
            class="body"
            style="font-size: 14px; margin: 0; padding-top: 14px; border-top: 1px solid var(--hairline);"
            data-en={e.desc.en}
            data-es={e.desc.es}
          >{e.desc.en}</p>
        </article>
      ))}
    </div>
  </section>
</div>
