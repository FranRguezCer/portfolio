---
import { STR, HOME_STACK } from '../../data/site';
import type { StackItem } from '../../data/types';

const en = STR.en;
const es = STR.es;
const base = import.meta.env.BASE_URL;
const iconUrl = (s: StackItem) =>
  s.iconPath ? `${base}${s.iconPath}` :
  s.slug ? `https://cdn.simpleicons.org/${s.slug}/black` :
  null;
// Render the marquee track twice so the loop is seamless; the second half
// is aria-hidden because it duplicates the first for animation purposes.
const tiles = [...HOME_STACK.map((s) => ({ s, hidden: false })), ...HOME_STACK.map((s) => ({ s, hidden: true }))];
---
<div class="container">
  <section id="stack" class="b-section">
    <div class="section-head">
      <div>
        <div class="eyebrow">
          <span class="num">03</span><span>/</span>
          <span data-en={en.sectionSubs.stack} data-es={es.sectionSubs.stack}>{en.sectionSubs.stack}</span>
        </div>
        <h2 class="h1" style="margin-top: 12px;">Stack</h2>
      </div>
    </div>
    <div class="stack-container">
      <div
        class="tech-marquee"
        aria-label="Technologies in use"
        data-aria-en="Technologies in use"
        data-aria-es="Tecnologías en uso"
      >
        <div class="tech-marquee-track">
          {tiles.map(({ s, hidden }) => {
            const url = iconUrl(s);
            return (
              <div class="tech-tile" aria-hidden={hidden ? 'true' : 'false'}>
                {url ? (
                  <span
                    class="stack-glyph"
                    role="img"
                    aria-label={s.label}
                    style={`-webkit-mask-image: url(${url}); mask-image: url(${url});`}
                  />
                ) : (
                  <span class="stack-glyph stack-glyph--text" role="img" aria-label={s.label}>{s.label}</span>
                )}
                <div class="name">{s.label}</div>
              </div>
            );
          })}
        </div>
      </div>
      <details class="stack-disclosure">
        <summary
          data-en={en.stackDisclosure}
          data-es={es.stackDisclosure}
        >{en.stackDisclosure}</summary>
        <ul class="tech-grid" aria-label="Full technology stack">
          {HOME_STACK.map((s) => {
            const url = iconUrl(s);
            return (
              <li class="tech-tile">
                {url ? (
                  <span
                    class="stack-glyph"
                    role="img"
                    aria-label={s.label}
                    style={`-webkit-mask-image: url(${url}); mask-image: url(${url});`}
                  />
                ) : (
                  <span class="stack-glyph stack-glyph--text" role="img" aria-label={s.label}>{s.label}</span>
                )}
                <div class="name">{s.label}</div>
              </li>
            );
          })}
        </ul>
      </details>
    </div>
  </section>
</div>

<script>
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelector('.stack-disclosure')?.setAttribute('open', '');
  }
</script>
